{
  "name": "@reflect-sdk/react-native",
  "version": "1.1.0",
  "description": "Reflect MMP SDK for React Native — mobile attribution, event tracking, and deep linking.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "reflect-react-native.podspec",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "typescript": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "attribution",
    "mmp",
    "mobile-measurement",
    "analytics",
    "reflect"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/retroage/reflect-sdk-react-native.git"
  },
  "author": "Retroage Engineering",
  "license": "MIT",
  "homepage": "https://reflect.bablu147147.workers.dev",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-builder-bob": "^0.23.0",
    "typescript": "^5.3.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      ["typescript", { "project": "tsconfig.build.json" }]
    ]
  }
}
